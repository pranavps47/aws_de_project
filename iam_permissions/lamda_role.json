{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "S3Access",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:ListBucket"
			],
			"Resource": [
				"arn:aws:s3:::aws-de-pipeline-bronze/*",
				"arn:aws:s3:::aws-de-pipeline-bronze",
				"arn:aws:s3:::aws-de-pipeline-silver/*",
				"arn:aws:s3:::aws-de-pipeline-silver"
			]
		},
		{
			"Sid": "GlueAccess",
			"Effect": "Allow",
			"Action": [
				"glue:GetTable",
				"glue:GetDatabase",
				"glue:CreateTable",
				"glue:UpdateTable",
				"glue:GetPartitions",
				"glue:CreatePartition",
				"glue:BatchCreatePartition"
			],
			"Resource": "*"
		},
		{
			"Sid": "SNSAccess",
			"Effect": "Allow",
			"Action": "sns:Publish",
			"Resource": "arn:aws:sns:ap-south-1:963524201534:aws-de-pipeline-alerts:e72e03a0-2a7b-4134-8bf3-09cb3aab8796"
		},
		{
			"Sid": "AthenaAccess",
			"Effect": "Allow",
			"Action": [
				"athena:StartQueryExecution",
				"athena:GetQueryExecution",
				"athena:GetQueryResults"
			],
			"Resource": "*"
		}
	]
}