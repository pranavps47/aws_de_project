{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3FullAccess",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:ListBucket",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::aws-de-pipeline-bronze/*",
                "arn:aws:s3:::aws-de-pipeline-bronze",
                "arn:aws:s3:::aws-de-pipeline-silver/*",
                "arn:aws:s3:::aws-de-pipeline-silver",
                "arn:aws:s3:::aws-de-pipeline-gold/*",
                "arn:aws:s3:::aws-de-pipeline-gold",
                "arn:aws:s3:::aws-de-pipeline-scripts/*",
                "arn:aws:s3:::aws-de-pipeline-scripts"
            ]
        }
    ]
}